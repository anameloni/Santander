Consulta en CLI paraobtener la cantidad minima de instancias pre-warmed:

Script Bash (Cloud Shell)

az graph query -q '
resources
| where type =~ "microsoft.web/serverfarms"
| where sku.name startswith "EP"
| project name, resourceGroup
' -o tsv \
| while read PLAN RG; do
  PREWARM=$(az functionapp plan show \
    --name "$PLAN" \
    --resource-group "$RG" \
    --query "properties.minimumElasticInstanceCount" -o tsv)
  echo "$PLAN | $RG | PreWarmed=$PREWARM"
done

