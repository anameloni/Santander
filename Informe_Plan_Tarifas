Ejecutar consulta:

resources
| where type =~ "microsoft.web/serverfarms"
| where sku.name startswith "EP"
| extend
    AppServicePlanId = tolower(id),
    AppServicePlanName = name,
    ResourceGroup = resourceGroup,
    PlanoTarifas = tostring(sku.name),
    MinPreWarmedInstances = toint(
        coalesce(
            properties.minimumElasticInstanceCount,
            properties.elasticScaleConfiguration.minimumElasticInstanceCount,
            0
        )
    )
| join kind=leftouter (
    resources
    | where type =~ "microsoft.web/sites"
    | where kind has "functionapp"
    | extend
        FunctionAppId = tolower(id),
        ServerFarmId = tolower(tostring(properties.serverFarmId)),
        FunctionAppName = name,
        FunctionResourceGroup = resourceGroup
) on $left.AppServicePlanId == $right.ServerFarmId
| project
    AppServicePlanName,
    AppServicePlanId,
    ResourceGroup,
    PlanoTarifas,
    MinPreWarmedInstances,
    FunctionAppName,
    FunctionAppId,
    FunctionResourceGroup
| order by ResourceGroup asc, AppServicePlanName asc


