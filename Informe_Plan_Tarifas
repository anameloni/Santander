Consulta con App plan ID y function ID

resources
| where type =~ "microsoft.web/serverfarms"
| where sku.name startswith "EP"
| project
    AppServicePlanId = id,
    AppServicePlanName = name,
    ResourceGroup = resourceGroup,
    PlanoTarifas = tostring(sku.name),
    MinPreWarmedInstances = iif(
        isnotempty(properties.minimumElasticInstanceCount),
        toint(properties.minimumElasticInstanceCount),
        0
    )
| join kind=leftouter (
    // Function Apps
    resources
    | where type =~ "microsoft.web/sites"
    | where kind =~ "functionapp"
    | project
        FunctionAppId = id,
        FunctionAppName = name,
        FunctionResourceGroup = resourceGroup,
        ServerFarmId = tostring(properties.serverFarmId)
) on $left.AppServicePlanId == $right.ServerFarmId
| project
    AppServicePlanName,
    AppServicePlanId,
    ResourceGroup,
    PlanoTarifas,
    MinPreWarmedInstances,
    FunctionAppName,
    FunctionAppId,
    FunctionResourceGroup
| order by ResourceGroup asc, AppServicePlanName asc



